<?xml version="1.0" encoding="utf-8"?>
<!-- Subtle top-down glow: a cool blue at the top fading into near-black, so the title and the
     cyan PLAY button read as lit against the dark. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#16314D"
        android:centerColor="#0D1117"
        android:endColor="#090C10"
        android:type="linear" />
</shape>
