<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <!-- CrossCode title art behind everything, dimmed so the UI stays legible. -->
    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:src="@drawable/bg_crosscode"
        android:contentDescription="@null" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- gravity=center keeps the column centered in 16:9 (no top-aligned scroll); it only
             scrolls if the screen is too short to fit. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="40dp"
            android:paddingVertical="20dp">

            <!-- CrossCode logo (replaces the old "CROSSCODE" text) -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="216dp"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:src="@drawable/logo_crosscode"
                android:contentDescription="CrossCode" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="STEAM CLOUD LAUNCHER"
                android:textColor="@color/play_cyan"
                android:textSize="12sp"
                android:letterSpacing="0.3" />

            <!-- ============ SIGNED-OUT STATE ============ -->
            <LinearLayout
                android:id="@+id/signed_out_group"
                android:layout_width="520dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Steam username"
                    android:textColorHint="@color/text_secondary"
                    app:boxStrokeColor="@color/play_cyan"
                    app:hintTextColor="@color/play_cyan">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/username"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="flagNoExtractUi"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Steam password"
                    android:textColorHint="@color/text_secondary"
                    app:boxStrokeColor="@color/play_cyan"
                    app:hintTextColor="@color/play_cyan"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:imeOptions="flagNoExtractUi"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sign_in_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:minHeight="50dp"
                    android:text="Sign in with Steam"
                    android:textColor="@color/play_text"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:backgroundTint="@color/play_cyan"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/focus_stroke"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/qr_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:minHeight="46dp"
                    android:text="Sign in with QR code"
                    android:textColor="@color/text_primary"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="@color/focus_stroke_outline"
                    app:strokeWidth="1dp"
                    app:rippleColor="@color/play_cyan" />
            </LinearLayout>

            <!-- ============ SIGNED-IN STATE ============ -->
            <LinearLayout
                android:id="@+id/signed_in_group"
                android:layout_width="520dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/account_line"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/play_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:minHeight="62dp"
                    android:text="▶  PLAY"
                    android:textColor="@color/play_text"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:textSize="21sp"
                    android:letterSpacing="0.08"
                    app:backgroundTint="@color/play_cyan"
                    app:cornerRadius="16dp"
                    app:elevation="6dp"
                    app:strokeColor="@color/focus_stroke"
                    app:strokeWidth="2dp" />

                <TextView
                    android:id="@+id/play_caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Pulls your latest save · uploads to Steam Cloud on quit"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center" />

                <CheckBox
                    android:id="@+id/offline_toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Play offline (skip cloud sync)"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:buttonTint="@color/play_cyan" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sign_out_button"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Sign out"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="false"
                    app:rippleColor="@color/text_secondary" />
            </LinearLayout>

            <!-- ============ SHARED: progress + status ============ -->
            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyle"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginTop="18dp"
                android:indeterminateTint="@color/play_cyan"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <ProgressBar
                android:id="@+id/download_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progressTint="@color/play_cyan"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <!-- Steam avatar, top-right (shown when signed in and downloaded) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatar"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="18dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:shapeAppearanceOverlay="@style/CircleAvatar"
        app:strokeColor="@color/play_cyan"
        app:strokeWidth="1.5dp"
        android:contentDescription="Steam avatar" />
</FrameLayout>
